# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://user:password@localhost:5432/gestion_credit_pro
MONGODB_URI=mongodb://localhost:27017/gestion_credit_pro
REDIS_URL=redis://localhost:6379/0

# === SÉCURITÉ ===
SECRET_KEY=change-moi-en-production-32-chars-min
JWT_SECRET_KEY=change-moi-aussi-jwt-secret-key

# === MOBILE MONEY APIs ===
# Wave Côte d'Ivoire
WAVE_API_BASE_URL=https://api.wave.com/v1
WAVE_API_KEY=your_wave_api_key_here
WAVE_MERCHANT_ID=your_wave_merchant_id

# Orange Money CI
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/ci/v1
ORANGE_MONEY_CLIENT_ID=your_om_client_id
ORANGE_MONEY_CLIENT_SECRET=your_om_client_secret
ORANGE_MONEY_MERCHANT_KEY=your_om_merchant_key

# MTN Mobile Money
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user
MTN_API_KEY=your_mtn_api_key

# === NOTIFICATIONS ===
# WhatsApp Business API (via Meta)
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# === ENVIRONNEMENT ===
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
MAX_CREDIT_MONTANT=500000
MIN_SCORE_POUR_CREDIT=40
